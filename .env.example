# 사용할 모델 제공자: gemini, openai 또는 ollama
# 원하는 모델에 따라 아래 주석을 해제하여 사용하세요.
# MODEL_PROVIDER=openai

MODEL_PROVIDER=ollama

# Ollama 설정 (로컬 또는 원격 서버 사용 시)
# Docker에서 호스트 PC의 Ollama를 사용할 때는 host.docker.internal:11434 를 사용합니다.
# 같은 컴퓨터에서 Docker 없이 직접 실행할 때만 비워두면 localhost:11434 기본값을 사용합니다.
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_MODEL=ollama_chat/llama3.1:8b


# Gemini 설정
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.0-flash



# OpenAI 설정
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini

# 서버 설정
APP_NAME=env_agent
AGENTS_DIR=agents
HOST=0.0.0.0
PORT=8000
SESSION_DB_URI=sqlite:////data/sessions.db
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
