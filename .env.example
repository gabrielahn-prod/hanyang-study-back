# 사용할 모델 제공자: gemini, openai 또는 ollama
MODEL_PROVIDER=ollama

# Ollama 설정 (로컬 또는 지훈님의 원격 서버 사용 시)
# 다른 컴퓨터(도커 등)에서 지훈님의 맥북 성능(인공지능)을 빌려쓰려면 아래에 지훈님 서버의 터널 주소를 적습니다.
# 예: OLLAMA_API_BASE=https://api.george-local-llm.com
# 같은 컴퓨터에서 실행하면 비워두셔도 됩니다 (기본값: http://localhost:11434).
OLLAMA_API_BASE=https://api.george-local-llm.com
OLLAMA_MODEL=ollama_chat/llama3.1:8b

# Gemini 설정
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI 설정
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=openai/gpt-4o-mini

# 서버 설정
APP_NAME=env_agent
AGENTS_DIR=agents
ADK_SERVER_MODE=api
HOST=0.0.0.0
PORT=8000
SESSION_DB_URI=sqlite:////data/sessions.db
ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
